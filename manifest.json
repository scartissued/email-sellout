{
  "manifest_version": 3,
  "name": "Email Alias Extension",
  "version": "1.0.0",
  "description": "Helps you generate and track +domain email aliases.",
  "action": {
    "default_popup": "index.html"
  },
  "options_page": "index.html",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"]
    }
  ],
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
